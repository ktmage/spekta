{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spekta.dev/schemas/behavior.schema.json",
  "title": "Spekta Behavior IR",
  "description": "Language-agnostic intermediate representation for behavior specifications. Structured as pages and sections, independent of any test framework.",
  "type": "object",
  "required": ["version", "pages"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version identifier."
    },
    "pages": {
      "type": "array",
      "description": "Top-level document units.",
      "items": {
        "$ref": "#/$defs/page"
      }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "description": "A document unit representing a specification page.",
      "required": ["id", "type", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this page."
        },
        "type": {
          "type": "string",
          "description": "The document type of this page (e.g. feature). Extensible for future types such as api or data_model."
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of this page."
        },
        "attributes": {
          "type": "array",
          "description": "Optional metadata attributes (summary, why, see, image, graph).",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        },
        "sections": {
          "type": "array",
          "description": "Child sections of this page.",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      }
    },
    "section": {
      "type": "object",
      "description": "A section within a page. Sections can nest recursively and may contain steps.",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this section."
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of this section."
        },
        "attributes": {
          "type": "array",
          "description": "Optional metadata attributes.",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        },
        "sections": {
          "type": "array",
          "description": "Nested child sections.",
          "items": {
            "$ref": "#/$defs/section"
          }
        },
        "steps": {
          "type": "array",
          "description": "Ordered sequence of actions. Present on leaf sections that describe specific behaviors.",
          "items": {
            "$ref": "#/$defs/step"
          }
        }
      }
    },
    "attribute": {
      "type": "object",
      "description": "Metadata attached to a page or section. The type field determines the kind of metadata.",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["summary", "why", "see", "image", "graph"],
          "description": "The kind of attribute. summary: overview text, why: rationale, see: reference to another page (via ref), image: image path, graph: Mermaid diagram text."
        },
        "text": {
          "type": "string",
          "description": "Text content of the attribute. Used by summary, why, image, and graph."
        },
        "ref": {
          "type": "string",
          "description": "Reference to another page by ID. Used by see attributes."
        }
      }
    },
    "step": {
      "type": "object",
      "description": "A single action or assertion within a section.",
      "required": ["action", "target"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["visit", "click_on", "fill_in", "select", "expect", "other"],
          "description": "The type of action."
        },
        "target": {
          "type": "string",
          "description": "The target of the action."
        },
        "value": {
          "type": "string",
          "description": "Optional value associated with the action."
        }
      }
    }
  }
}
