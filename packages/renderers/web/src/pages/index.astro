---
import { loadIR } from "../lib/ir";

const ir = await loadIR();
const firstPage = ir.pages[0];
const redirectUrl = `/${firstPage.id}/`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
    <link rel="canonical" href={redirectUrl} />
    <title>リダイレクト中...</title>
  </head>
  <body>
    <p><a href={redirectUrl}>こちらをクリックしてください</a></p>
  </body>
</html>
