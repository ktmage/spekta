---
import { loadIR, loadSiteInfo, findPageById } from "../lib/ir";
import type { Page, SiteInfo } from "../lib/ir";
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

export async function getStaticPaths() {
  const ir = await loadIR();
  const site = await loadSiteInfo();
  return ir.pages.map((page: Page) => ({
    params: { slug: page.id },
    props: { page, pages: ir.pages, site },
  }));
}

interface Props {
  page: Page;
  pages: Page[];
  site: SiteInfo;
}

const { page, pages, site } = Astro.props;

// Extract page-level attributes
const summary = page.attributes?.find((a) => a.type === "summary");
const seeRefs = page.attributes?.filter((a) => a.type === "see") ?? [];
const imageAttr = page.attributes?.find((a) => a.type === "image");
const graphAttr = page.attributes?.find((a) => a.type === "graph");
---

<BaseLayout title={page.title} pages={pages} currentPageId={page.id} site={site}>
  <div class="spec-content">
    <h1 class="spec-content__title">{page.title}</h1>

    {summary?.text && (
      <p class="spec-content__summary">{summary.text}</p>
    )}

    {seeRefs.length > 0 && (
      <div class="spec-content__related">
        <span class="spec-content__related-label">関連:</span>
        {seeRefs.map((attr) => {
          const refPage = findPageById(pages, attr.ref ?? "");
          return refPage ? (
            <a href={`/${refPage.id}/`} class="spec-content__related-link">
              {refPage.title}
            </a>
          ) : null;
        })}
      </div>
    )}

    {imageAttr?.text && (
      <div class="spec-image">
        <img src={`/data/images/${imageAttr.text.split('/').pop()}`} alt={page.title} />
      </div>
    )}

    {graphAttr?.text && (
      <div class="spec-graph">
        <div class="mermaid">{graphAttr.text}</div>
      </div>
    )}

    {page.sections && page.sections.length > 0 && (
      <div class="spec-content__body">
        {page.sections.map((section) => (
          <Section
            section={section}
            depth={1}
            pages={pages}
            currentPageId={page.id}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
