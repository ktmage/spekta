---
import type { Page, SiteInfo } from "../lib/ir";
import Sidebar from "../components/Sidebar.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import MobileMenu from "../components/MobileMenu";
import "../styles/global.css";

interface Props {
  title: string;
  pages: Page[];
  currentPageId: string;
  site: SiteInfo;
}

const { title, pages, currentPageId, site } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - {site.name || "Spekta"}</title>
    <script is:inline type="module"
      src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
    ></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        if (typeof mermaid !== "undefined") {
          mermaid.initialize({ startOnLoad: true, theme: "neutral" });
        }
      });
    </script>
  </head>
  <body>
    <Sidebar pages={pages} currentPageId={currentPageId} />
    <main class="main-content" id="main-content">
      <SiteHeader site={site} />
      <slot />
      <SiteFooter site={site} />
    </main>
    <MobileMenu client:load />
  </body>
</html>
