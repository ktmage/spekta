---
import type { Page } from "../lib/ir";
import { collectSearchEntries } from "../lib/ir";
import Search from "./Search";

interface Props {
  pages: Page[];
  currentPageId: string;
}

const { pages, currentPageId } = Astro.props;
const searchEntries = collectSearchEntries(pages);
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar__header">
    <div class="sidebar__label">目次</div>
  </div>

  <div class="sidebar__search">
    <Search entries={searchEntries} client:load />
  </div>

  <nav class="sidebar__nav">
    {pages.map((page) => {
      const isActive = page.id === currentPageId;
      return (
        <div class="sidebar__section">
          <details open={isActive}>
            <summary>
              <a
                href={`/${page.id}/`}
                class:list={[
                  "sidebar__link",
                  "sidebar__link--top",
                  { "sidebar__link--active": isActive },
                ]}
              >
                <span class="sidebar__link-label">{page.title}</span>
                <span class="sidebar__toggle">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M4.5 2.5L8 6L4.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            </summary>
            {page.sections && page.sections.length > 0 && (
              <ul class="sidebar__subtree">
                {page.sections.map((section) => (
                  <li>
                    <a href={`/${page.id}/#${section.id}`} class="sidebar__sublink">
                      {section.title}
                    </a>
                    {section.sections && section.sections.length > 0 && (
                      <ul class="sidebar__subtree">
                        {section.sections.map((child) => (
                          <li>
                            <a href={`/${page.id}/#${child.id}`} class="sidebar__sublink sidebar__sublink--leaf">
                              {child.title}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </details>
        </div>
      );
    })}
  </nav>
</aside>
