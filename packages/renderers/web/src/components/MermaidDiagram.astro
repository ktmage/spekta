---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="spec-graph">
  <div class="mermaid">
    {text}
  </div>
</div>

<script is:inline>
  // Re-run mermaid rendering for dynamically loaded content
  if (typeof mermaid !== "undefined") {
    mermaid.run();
  }
</script>
